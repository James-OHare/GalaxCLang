{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GalaxC",
  "scopeName": "source.galaxc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#annotations" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.galaxc",
          "match": "--.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.galaxc",
          "match": "\\b(if|else|while|loop|for|in|match|select|accept|or|delay|when|return|break|continue|end|op|struct|enum|task|protected|unit|try|catch|dock|orbit)\\b"
        },
        {
          "name": "storage.type.galaxc",
          "match": "\\b(let|var|const|auto)\\b"
        },
        {
          "name": "storage.modifier.galaxc",
          "match": "\\b(pub|mut|ref)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.galaxc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.galaxc",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.galaxc",
          "match": "'([^'\\\\]|\\\\.)'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.galaxc",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.galaxc",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.galaxc",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.galaxc",
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9][0-9_]*)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.galaxc",
          "match": "\\b(true|false|none|self|Self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.galaxc",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.function.annotation.galaxc",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.galaxc",
          "match": "(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|<<|>>|=|\\+=|\\-=|\\*=|/=|%=|=>|->|::|\\.\\.|\\+\\+|\\?)"
        }
      ]
    }
  }
}
