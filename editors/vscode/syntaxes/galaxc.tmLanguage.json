{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GalaxC",
  "scopeName": "source.galaxc",
  "patterns": [
    {
      "name": "keyword.control.galaxc",
      "match": "\\b(op|let|var|const|struct|enum|match|if|else|while|loop|for|end|orbit|dock)\\b"
    },
    {
      "name": "string.quoted.double.galaxc",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "comment.line.double-dash.galaxc",
      "match": "--.*$"
    }
  ]
}
