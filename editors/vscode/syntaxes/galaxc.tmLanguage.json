{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GalaxC",
  "scopeName": "source.galaxc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#annotations" },
    { "include": "#units" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#paths" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.galaxc",
          "match": "---.*$"
        },
        {
          "name": "comment.line.double-dash.galaxc",
          "match": "--.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.galaxc",
          "match": "\\b(if|else|while|loop|for|in|match|select|accept|or|delay|when|return|break|continue|end|op|struct|enum|ability|impl|task|protected|unit|try|catch|dock|orbit|safe)\\b"
        },
        {
          "name": "storage.type.galaxc",
          "match": "\\b(let|var|const|auto)\\b"
        },
        {
          "name": "storage.modifier.galaxc",
          "match": "\\b(pub|mut|ref|own|async)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.galaxc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.galaxc",
              "match": "\\\\[0tnr\"'\\\\]"
            },
            {
              "name": "constant.character.escape.unicode.galaxc",
              "match": "\\\\u\\{[0-9a-fA-F]+\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.galaxc",
          "match": "'([^'\\\\]|\\\\.)'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.galaxc",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.galaxc",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.galaxc",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.galaxc",
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.galaxc",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.galaxc",
          "match": "\\b(true|false|none|self|Self|ok|err)\\b"
        }
      ]
    },
    "units": {
      "patterns": [
        {
          "name": "storage.type.unit.galaxc",
          "match": "(?<=<)[a-zA-Z_][a-zA-Z0-9_]*(?=>)"
        },
        {
          "name": "punctuation.definition.unit.galaxc",
          "match": "[<>]"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.galaxc",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.galaxc",
          "match": "\\b[a-z_][a-z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "variable.other.member.galaxc",
          "match": "(?<=\\.)[a-z_][a-z0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.function.annotation.galaxc",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "paths": {
      "patterns": [
        {
          "name": "keyword.operator.path.galaxc",
          "match": "::"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.galaxc",
          "match": "(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|<<|>>|=|\\+=|\\-=|\\*=|/=|%=|=>|->|\\.\\.|\\+\\+|\\?|!!)"
        }
      ]
    }
  }
}
